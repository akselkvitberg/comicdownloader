{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"command": "go",
			"args": ["build", "./..."],
			"type": "process",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$go"
		},
		{
			"label": "test",
			"command": "go",
			"args": ["test", "./...", "-v"],
			"type": "process",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": "$go"
		},
		{
			"label": "run",
			"command": "go",
			"args": ["run", "."],
			"type": "process",
			"isBackground": true,
			"problemMatcher": "$go"
		}
	]
}
