# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
project_id        = "your-gcp-project-id"
app_bucket_name   = "your-app-bucket-name"
github_repository = "your-org/comicdownloader"

# image is supplied by CI; for a manual apply, pin a real pushed image:
# image = "europe-west1-docker.pkg.dev/your-gcp-project-id/comicdownloader/comicdownloader@sha256:..."

# Optional:
# region                      = "europe-west1"
# calvin_hobbes_source_bucket = "calvin-and-hobbes-342ndf3"
# otlp_traces_endpoint        = "https://your-collector:4317"
# download_schedule           = "0 */5 * * *"
# refresh_schedule            = "0 0 * * *"
# scheduler_time_zone         = "Europe/Oslo"
